# ==============================================================================
# FINDING_AI Environment Configuration File Template
# Copy this file to '.env' in your backend directory and populate your credentials.
# Do NOT commit your actual '.env' file containing real secrets to GitHub!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. System & Server Configuration
# ------------------------------------------------------------------------------
APP_ENV=development # Options: development, staging, production
PROJECT_NAME="FINDING_AI"
DEBUG=true
PORT=8000
API_V1_STR="/api/v1"

# ------------------------------------------------------------------------------
# 2. Database Configuration (PostgreSQL + pgvector)
# ------------------------------------------------------------------------------
# Format: postgresql://[user]:[password]@[host]:[port]/[database_name]
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finding_ai_db"

# ------------------------------------------------------------------------------
# 3. JWT Security & User Authentication
# ------------------------------------------------------------------------------
# Generate a secure 32-character key using: openssl rand -hex 32
JWT_SECRET_KEY="replace_me_with_a_secure_random_hex_string_32_chars"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------------------------------------------
# 4. Local LLM Configuration (Ollama API)
# ------------------------------------------------------------------------------
OLLAMA_API_URL="http://localhost:11434"
OLLAMA_PARSING_MODEL="llama3"         # Model used for parsing resume text
OLLAMA_EMBEDDING_MODEL="nomic-embed-text" # Model used for generating skill vectors
OLLAMA_ADVICE_MODEL="llama3"          # Model used for resume improvement assistant

# ------------------------------------------------------------------------------
# 5. File Upload & Document Storage
# ------------------------------------------------------------------------------
# Location to store uploaded resume PDF/DOCX/TXT documents
UPLOAD_STORAGE_TYPE="local" # Options: local, s3
LOCAL_UPLOAD_DIR="./uploads/resumes"

# AWS S3 Storage Configurations (If UPLOAD_STORAGE_TYPE is set to "s3")
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION_NAME="us-east-1"
AWS_STORAGE_BUCKET_NAME="finding-ai-resumes"

# ------------------------------------------------------------------------------
# 6. Email Service (SMTP) for Registration & Recovery
# ------------------------------------------------------------------------------
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST="smtp.gmail.com"
SMTP_USER=""
SMTP_PASSWORD=""
EMAILS_FROM_EMAIL="noreply@findingai.org"
EMAILS_FROM_NAME="FINDING_AI Platform"

# ------------------------------------------------------------------------------
# 7. CORS Allowed Origins (Comma-separated list)
# ------------------------------------------------------------------------------
BACKEND_CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000"
